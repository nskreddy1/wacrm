{
  "name": "wacrm",
  "version": "0.8.0",
  "private": true,
  "description": "Self-hostable CRM template for WhatsApp built on Next.js and Supabase — shared inbox, contacts, sales pipelines, broadcasts, and no-code automations.",
  "license": "MIT",
  "author": "Arnas Donauskas",
  "homepage": "https://github.com/ArnasDon/wacrm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArnasDon/wacrm.git"
  },
  "bugs": {
    "url": "https://github.com/ArnasDon/wacrm/issues"
  },
  "keywords": [
    "crm",
    "whatsapp",
    "whatsapp-business-api",
    "nextjs",
    "supabase",
    "automation",
    "broadcast",
    "self-hosted",
    "template"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,api --prefix-colors cyan,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "node --env-file-if-exists=.env.development.local scripts/run-web.mjs dev",
    "dev:api": "node --env-file-if-exists=.env.development.local --import tsx --watch server/index.ts",
    "build": "next build",
    "start": "concurrently --kill-others-on-fail --names web,api --prefix-colors cyan,green \"pnpm start:web\" \"pnpm start:api\"",
    "start:web": "node --env-file-if-exists=.env.development.local scripts/run-web.mjs start",
    "start:api": "node --env-file-if-exists=.env.development.local --import tsx server/index.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.107.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.6",
    "next-intl": "^4.13.1",
    "nodemailer": "^9.0.3",
    "opus-recorder": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^6",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "ip-address": "^10.1.1",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.25",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  }
}
